-- 2. Fungsi Denghub UI (muncul sebentar lalu auto-close)
local function showDenghubUI()
    local Gui = Instance.new("ScreenGui")
    Gui.Name = "DenghubUI"
    Gui.Parent = game:GetService("CoreGui")

    local Frame = Instance.new("Frame")
    Frame.Size = UDim2.new(0, 300, 0, 150)
    Frame.Position = UDim2.new(0.5, -150, 0.5, -75)
    Frame.BackgroundColor3 = Color3.fromRGB(25, 25, 25)
    Frame.BorderSizePixel = 0
    Frame.Parent = Gui

    local Title = Instance.new("TextLabel")
    Title.Size = UDim2.new(1, 0, 0, 30)
    Title.BackgroundTransparency = 1
    Title.Text = "Denghub - Server Detector"
    Title.TextColor3 = Color3.fromRGB(255, 255, 255)
    Title.TextScaled = true
    Title.Font = Enum.Font.GothamBold
    Title.Parent = Frame

    local CloseBtn = Instance.new("TextButton")
    CloseBtn.Size = UDim2.new(0, 100, 0, 30)
    CloseBtn.Position = UDim2.new(0.5, -50, 0.6, 0)
    CloseBtn.Text = "Tutup Manual"
    CloseBtn.BackgroundColor3 = Color3.fromRGB(200, 50, 50)
    CloseBtn.TextColor3 = Color3.fromRGB(255, 255, 255)
    CloseBtn.Parent = Frame
    CloseBtn.MouseButton1Click:Connect(function()
        Gui:Destroy()
    end)

    -- Auto-close setelah 3 detik
    task.wait(3)
    if Gui and Gui.Parent then
        Gui:Destroy()
    end
end

-- 3. Minimize / tutup script ReduceMons (coba cari GUI-nya)
local function minimizeReduceMons()
    local reduceGui = game:GetService("CoreGui"):FindFirstChild("ReduceMonsUI")
    if reduceGui then
        reduceGui.Enabled = false  -- Minimize (bisa juga :Destroy())
        print("[Wrapper] ReduceMons GUI diminimize.")
    else
        print("[Wrapper] ReduceMons GUI tidak ditemukan.")
    end
end

-- 4. Tutup Delta Executor
local function closeDelta()
    -- Cara resmi di Delta biasanya executor:quit()
    pcall(function()
        if executor and executor.quit then
            executor.quit()
        end
    end)
    -- Fallback lain (beberapa executor pakai syn.quit)
    pcall(function()
        if syn and syn.quit then
            syn.quit()
        end
    end)
end

-- 5. Jalankan semua fitur tambahan
task.spawn(showDenghubUI)          -- Muncul UI di background
task.wait(1)
minimizeReduceMons()
task.wait(1)
closeDelta()
