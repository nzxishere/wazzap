local function Tween(obj, props, duration, style, dir)
    local info = TweenInfo.new(
        duration or 0.25,
        style or Enum.EasingStyle.Quart,
        dir or Enum.EasingDirection.Out
    )
    TweenService:Create(obj, info, props):Play()
end

local function GetPingColor(ping)
    local T = CONFIG.Theme
    if ping < 80  then return T.Good
    elseif ping < 150 then return T.Warn
    else return T.Bad end
end

local function GetFPSColor(fps)
    local T = CONFIG.Theme
    if fps >= 55 then return T.Good
    elseif fps >= 30 then return T.Warn
    else return T.Bad end
end

local function AvgPing()
    if #pingHistory == 0 then return 0 end
    local s = 0
    for _, v in ipairs(pingHistory) do s = s + v end
    return math.floor(s / #pingHistory)
end

local function GetRegion()
    -- Deteksi region dari JobId prefix / DataCenter jika tersedia
    local ok, region = pcall(function()
        return game:GetService("Stats"):FindFirstChild("DataCenterName")
            and game:GetService("Stats").DataCenterName.Value
            or "Unknown"
    end)
    return ok and region or "Unknown"
end

local function GetServerAge()
    local ok, age = pcall(function()
        return math.floor(workspace.DistributedGameTime)
    end)
    return ok and age or 0
end

local function FormatTime(s)
    local m = math.floor(s / 60)
    local sec = s % 60
    if m > 0 then
        return string.format("%dm %ds", m, sec)
    end
    return string.format("%ds", sec)
end

local function GetServerLoad()
    -- Estimasi load dari HeartbeatTime
    local ok, hb = pcall(function()
        return Stats.HeartbeatTimeMs
    end)
    if ok and hb then
        local v = hb.Value
        if v < 8 then return "Ringan", CONFIG.Theme.Good
        elseif v < 20 then return "Sedang", CONFIG.Theme.Warn
        else return "Berat", CONFIG.Theme.Bad end
    end
    return "N/A", CONFIG.Theme.SubText
end

