-- ┌─────────────────────────────────────────────┐
-- │         AUTO CLOSE EXECUTOR UI              │
-- └─────────────────────────────────────────────┘
local function CloseExecutorUI()
    if not CONFIG.AutoCloseExecutorUI then return end

    -- Delta UI
    local deltaTargets = {
        "DeltaExecutorUI",
        "DeltaUI",
        "Delta_Main",
        "DeltaFrame",
    }
    -- DengHub UI
    local dengTargets = {
        "DengHub",
        "DengHubUI",
        "DengHub_Frame",
        "DengHubMain",
    }

    local allTargets = {}
    for _, v in ipairs(deltaTargets) do table.insert(allTargets, v) end
    for _, v in ipairs(dengTargets)  do table.insert(allTargets, v) end

    -- Cari dan destroy di semua layer UI
    local layers = {
        game:GetService("CoreGui"),
        game:GetService("Players").LocalPlayer:WaitForChild("PlayerGui", 5),
    }

    for _, layer in ipairs(layers) do
        if layer then
            for _, name in ipairs(allTargets) do
                local found = layer:FindFirstChild(name, true)
                if found then
                    pcall(function() found:Destroy() end)
                end
            end
            -- Fallback: scan semua ScreenGui yang mengandung nama executor
            for _, obj in ipairs(layer:GetChildren()) do
                local n = obj.Name:lower()
                if n:find("delta") or n:find("denghub") or n:find("deng") then
                    pcall(function() obj:Destroy() end)
                end
            end
        end
    end
end

