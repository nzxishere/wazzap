            else
                -- ══ PASTE SCRIPT KAMU DI SINI ══
                -- contoh: loadstring(game:HttpGet("https://...", true))()
                warn("[ServerTest] ScriptURL kosong. Isi CONFIG.ScriptURL atau paste script di sini.")
