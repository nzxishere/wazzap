-- ┌─────────────────────────────────────────────┐
-- │           UPDATE LOOP (MONITORING)          │
-- └─────────────────────────────────────────────┘
local lastFPS    = 60
local frameCount = 0
local elapsed    = 0

local fpsConn = RunService.RenderStepped:Connect(function(dt)
    frameCount = frameCount + 1
    elapsed    = elapsed + dt
    if elapsed >= 1 then
        lastFPS    = math.floor(frameCount / elapsed)
        frameCount = 0
        elapsed    = 0
    end
end)
table.insert(connections, fpsConn)

local updateConn = RunService.Heartbeat:Connect(function()
    -- Ping
    local ping = LocalPlayer:GetNetworkPing and
                 math.floor(LocalPlayer:GetNetworkPing() * 1000) or
                 0

    table.insert(pingHistory, ping)
    if #pingHistory > CONFIG.MaxPingSamples then
        table.remove(pingHistory, 1)
    end

    local avg = AvgPing()
    vPing.Text      = avg .. " ms  (now: " .. ping .. " ms)"
    vPing.TextColor3 = GetPingColor(avg)

    -- FPS
    vFPS.Text       = lastFPS .. " fps"
    vFPS.TextColor3 = GetFPSColor(lastFPS)

    -- Players
    local pCount    = #Players:GetPlayers()
    local maxP      = game.Players.MaxPlayers
    vPlayers.Text   = pCount .. " / " .. maxP .. " players"
    local pRatio    = pCount / math.max(maxP, 1)
    vPlayers.TextColor3 = pRatio > 0.8 and T.Bad
                       or pRatio > 0.5 and T.Warn
                       or T.Good

    -- Uptime
    local age = GetServerAge()
    vUptime.Text = FormatTime(age)
    vUptime.TextColor3 = T.Text

    -- Server Load
    local loadText, loadColor = GetServerLoad()
    vLoad.Text       = loadText
    vLoad.TextColor3 = loadColor

    -- Status dot pulse via color
    local pulse = math.abs(math.sin(tick() * 2))
    StatusDot.BackgroundColor3 = Color3.fromRGB(
        math.floor(52 + pulse * 30),
        math.floor(211 - pulse * 10),
        math.floor(153 - pulse * 20)
    )
end)
table.insert(connections, updateConn)

