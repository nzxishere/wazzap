        end)

        if ok then
            RunBtn.Text = "✅ Script Berjalan"
            Tween(RunBtn, {BackgroundColor3 = T.Good}, 0.2)
            StatusText.Text = "Script aktif — monitoring lanjut"

            -- Auto minimize setelah script jalan
